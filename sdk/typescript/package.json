{
  "name": "dap-sdk",
  "version": "0.1.0",
  "description": "Minimal TypeScript SDK for the Delegated Agent Protocol (DAP) v0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "example": "tsx examples/end-to-end.ts",
    "demo": "tsx examples/demo.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dap-protocol/dap",
    "directory": "sdk/typescript"
  },
  "keywords": [
    "dap",
    "agent",
    "credential",
    "delegation",
    "protocol"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "jose": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
